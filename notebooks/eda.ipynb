    "def create_aggregate_features(df):\n",
    "\n",
    "    agg_df = (\n",
    "        df.groupby('CustomerId')\n",
    "        .agg(\n",
    "            total_transaction_amount=(\n",
    "                'Amount',\n",
    "                'sum'\n",
    "            ),\n",
    "            \n",
    "            avg_transaction_amount=(\n",
    "                'Amount',\n",
    "                'mean'\n",
    "            ),\n",
    "            \n",
    "            transaction_count=(\n",
    "                'Amount',\n",
    "                'count'\n",
    "            ),\n",
    "            \n",
    "            std_transaction_amount=(\n",
    "                'Amount',\n",
    "                'std'\n",
    "            )\n",
    "        )\n",
    "        .reset_index()\n",
    "    )\n",
    "\n",
    "    return agg_df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "fe451055-76d0-490d-bdbc-1b9e7210b95c",
   "metadata": {},
   "outputs": [],
   "source": [
    "agg_df = create_aggregate_features(df)\n",
    "\n",
    "df = df.merge(\n",
    "    agg_df,\n",
    "    on='CustomerId',\n",
    "    how='left'\n",
    ")"
   ]
