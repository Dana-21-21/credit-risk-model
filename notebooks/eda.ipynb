   "source": [
    "lr_metrics = evaluate_model(\n",
    "    y_test,\n",
    "    lr_pred,\n",
    "    lr_prob\n",
    ")\n",
    "\n",
    "rf_metrics = evaluate_model(\n",
    "    y_test,\n",
    "    rf_pred,\n",
    "    rf_prob\n",
    ")"
   ]
  },
