   "source": [
    "from sklearn.metrics import (\n",
    "    accuracy_score,\n",
    "    precision_score,\n",
    "    recall_score,\n",
    "    f1_score,\n",
    "    roc_auc_score\n",
    ")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 175,
   "id": "103c9b48-75b3-44af-9f8c-34a7db771cd5",
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate_model(\n",
    "    y_true,\n",
    "    y_pred,\n",
    "    y_prob\n",
    "):\n",
    "    return {\n",
    "        \"accuracy\":\n",
    "        accuracy_score(y_true,y_pred),\n",
    "\n",
    "        \"precision\":\n",
    "        precision_score(y_true,y_pred),\n",
    "\n",
    "        \"recall\":\n",
    "        recall_score(y_true,y_pred),\n",
    "\n",
    "        \"f1\":\n",
    "        f1_score(y_true,y_pred),\n",
    "\n",
    "        \"roc_auc\":\n",
    "        roc_auc_score(y_true,y_prob)\n",
    "    }"
   ]
  },
  {
   "cell_type": "code",
